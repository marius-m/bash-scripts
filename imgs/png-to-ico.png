#!/bin/sh
#set -x
export LANG=en_US.UTF-8
INPUT_FILE=$1
FILENAME=$(basename -- "$INPUT_FILE")
EXT="${FILENAME##*.}"
FILENAME="${FILENAME%.*}"
TARGET_EXT="ico"

NEW_NAME_EXT=$(echo $1 | sed s/.${EXT}/-clip.${TARGET_EXT}/g)
if [[ $INPUT_FILE == ${NEW_NAME_EXT} ]]; then
  echo "Same name used for output (${INPUT_FILE})!"
  exit 1
fi

if [[ -f $INPUT_FILE ]]; then
  echo "Converting ($INPUT_FILE -> $NEW_NAME_EXT)..."
else
  echo "File not found (${INPUT_FILE})!"
  exit 1
fi

convert -resize x16 -gravity center -crop 16x16+0+0 $INPUT_FILE -flatten -colors 256 -background transparent $NEW_NAME_EXT
echo "Complete '${NEW_NAME_EXT}'"
